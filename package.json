{
  "name": "breaportfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run audit && vite build",
    "audit": "node scripts/audit-assets.js",
    "lint": "eslint .",
